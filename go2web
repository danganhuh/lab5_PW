#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import socket
import ssl
import sys
from dataclasses import dataclass
from html import unescape
from html.parser import HTMLParser
from urllib.parse import quote_plus, urljoin, urlparse

DEFAULT_TIMEOUT = 5.0
USER_AGENT = "go2web/0.1"
MAX_REDIRECTS = 5


@dataclass
class ParsedHttpResponse:
    status_line: str
    status_code: int
    headers: dict[str, str]
    content_type: str
    location: str
    body: bytes


class TitleParser(HTMLParser):
    def __init__(self) -> None:
        super().__init__()
        self._in_title = False
        self._parts: list[str] = []

    def handle_starttag(self, tag: str, attrs: list[tuple[str, str | None]]) -> None:
        if tag.lower() == "title":
            self._in_title = True

    def handle_endtag(self, tag: str) -> None:
        if tag.lower() == "title":
            self._in_title = False

    def handle_data(self, data: str) -> None:
        if self._in_title:
            self._parts.append(data)

    @property
    def title(self) -> str:
        return " ".join(p.strip() for p in self._parts if p.strip()).strip()


class VisibleTextParser(HTMLParser):
    def __init__(self) -> None:
        super().__init__()
        self._ignore_depth = 0
        self._parts: list[str] = []

    def handle_starttag(self, tag: str, attrs: list[tuple[str, str | None]]) -> None:
        if tag.lower() in {"script", "style"}:
            self._ignore_depth += 1

    def handle_endtag(self, tag: str) -> None:
        if tag.lower() in {"script", "style"} and self._ignore_depth > 0:
            self._ignore_depth -= 1
        if tag.lower() in {"p", "br", "div", "li", "section", "article", "h1", "h2", "h3"}:
            self._parts.append("\n")

    def handle_data(self, data: str) -> None:
        if self._ignore_depth == 0:
            text = data.strip()
            if text:
                self._parts.append(text)

    def get_text(self) -> str:
        merged = " ".join(self._parts)
        lines = [line.strip() for line in merged.splitlines()]
        lines = [line for line in lines if line]
        return "\n".join(lines)


def decode_body_text(body: bytes, content_type: str) -> str:
    charset = "utf-8"
    for part in content_type.split(";")[1:]:
        name, sep, value = part.strip().partition("=")
        if sep and name.lower() == "charset" and value:
            charset = value.strip().strip('"').strip("'")
            break
    return body.decode(charset, errors="replace")


def format_response_content(body: bytes, content_type: str) -> str:
    lowered = content_type.lower()
    text = decode_body_text(body, content_type)

    if "application/json" in lowered or lowered.endswith("+json"):
        try:
            parsed = json.loads(text)
            return json.dumps(parsed, indent=2, ensure_ascii=False)
        except json.JSONDecodeError:
            return text

    if "text/html" in lowered:
        parser = VisibleTextParser()
        parser.feed(text)
        return unescape(parser.get_text())

    return text


def recv_all(sock: socket.socket) -> bytes:
    chunks: list[bytes] = []
    while True:
        chunk = sock.recv(4096)
        if not chunk:
            break
        chunks.append(chunk)
    return b"".join(chunks)


def parse_http_response(raw_response: bytes) -> ParsedHttpResponse:
    header_end = raw_response.find(b"\r\n\r\n")
    if header_end == -1:
        raise ValueError("Invalid HTTP response: missing header separator")

    header_blob = raw_response[:header_end].decode("iso-8859-1", errors="replace")
    body = raw_response[header_end + 4 :]
    header_lines = header_blob.split("\r\n")
    status_line = header_lines[0] if header_lines else "HTTP/1.1 000 Unknown"

    headers: dict[str, str] = {}
    for line in header_lines[1:]:
        if ":" not in line:
            continue
        key, value = line.split(":", 1)
        headers[key.strip().lower()] = value.strip()
    status_code = 0
    parts = status_line.split()
    if len(parts) >= 2 and parts[1].isdigit():
        status_code = int(parts[1])

    return ParsedHttpResponse(
        status_line=status_line,
        status_code=status_code,
        headers=headers,
        content_type=headers.get("content-type", ""),
        location=headers.get("location", ""),
        body=body,
    )


def decode_chunked_body(chunked: bytes) -> bytes:
    data = chunked
    decoded = bytearray()
    idx = 0

    while True:
        line_end = data.find(b"\r\n", idx)
        if line_end == -1:
            raise ValueError("Invalid chunked response: missing chunk size line")
        size_line = data[idx:line_end].decode("ascii", errors="replace").strip()
        size_token = size_line.split(";", 1)[0].strip()
        try:
            chunk_size = int(size_token, 16)
        except ValueError as exc:
            raise ValueError("Invalid chunked response: bad chunk size") from exc

        idx = line_end + 2
        if chunk_size == 0:
            break

        chunk_end = idx + chunk_size
        if chunk_end > len(data):
            raise ValueError("Invalid chunked response: incomplete chunk")
        decoded.extend(data[idx:chunk_end])
        idx = chunk_end + 2  # Skip trailing CRLF after chunk data.

    return bytes(decoded)


def fetch_http_via_socket(
    host: str, port: int, path: str, timeout: float, use_tls: bool
) -> ParsedHttpResponse:
    default_port = 443 if use_tls else 80
    host_header = host if port == default_port else f"{host}:{port}"
    request = (
        f"GET {path} HTTP/1.1\r\n"
        f"Host: {host_header}\r\n"
        f"User-Agent: {USER_AGENT}\r\n"
        "Connection: close\r\n"
        "\r\n"
    ).encode("ascii", errors="replace")

    with socket.create_connection((host, port), timeout=timeout) as sock:
        if use_tls:
            context = ssl.create_default_context()
            with context.wrap_socket(sock, server_hostname=host) as tls_sock:
                tls_sock.sendall(request)
                raw_response = recv_all(tls_sock)
        else:
            sock.sendall(request)
            raw_response = recv_all(sock)

    response = parse_http_response(raw_response)
    transfer_encoding = response.headers.get("transfer-encoding", "").lower()
    if "chunked" in transfer_encoding:
        response.body = decode_chunked_body(response.body)
    return response


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="go2web",
        add_help=False,
        formatter_class=argparse.RawTextHelpFormatter,
        description=(
            "go2web - CLI web helper\n\n"
            "Usage:\n"
            "  go2web -h\n"
            "  go2web -u <URL>\n"
            "  go2web -s <search-term>"
        ),
    )
    parser.add_argument("-h", "--help", action="store_true", help="Show this help message and exit")
    parser.add_argument("-u", metavar="URL", dest="url", help="Fetch URL and print page title")
    parser.add_argument("-s", metavar="TERM", dest="search_term", help="Search term handler")
    parser.add_argument("--timeout", type=float, default=DEFAULT_TIMEOUT, help="HTTP timeout in seconds")
    return parser


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = build_parser()
    return parser.parse_args(argv)


def parse_web_url(url: str) -> tuple[str, str, int, str]:
    parsed = urlparse(url)
    scheme = parsed.scheme.lower()
    if scheme not in {"http", "https"}:
        raise ValueError("Only http:// and https:// URLs are supported")
    if not parsed.hostname:
        raise ValueError("Invalid URL: missing host")

    host = parsed.hostname
    default_port = 443 if scheme == "https" else 80
    port = parsed.port or default_port
    path = parsed.path if parsed.path else "/index.html"
    if parsed.query:
        path = f"{path}?{parsed.query}"
    return scheme, host, port, path


def handle_url(url: str, timeout: float) -> int:
    if not url:
        print("Error: missing URL after -u", file=sys.stderr)
        return 2
    current_url = url
    redirect_count = 0
    response: ParsedHttpResponse | None = None

    while True:
        try:
            scheme, host, port, path = parse_web_url(current_url)
        except ValueError as exc:
            print(f"Error: {exc}", file=sys.stderr)
            return 2

        print(f"Scheme: {scheme}")
        print(f"Host: {host}")
        print(f"Port: {port}")
        print(f"Path: {path}")

        try:
            response = fetch_http_via_socket(
                host=host, port=port, path=path, timeout=timeout, use_tls=(scheme == "https")
            )
        except (OSError, ValueError, ssl.SSLError) as exc:
            print(f"Network error: {exc}", file=sys.stderr)
            return 1

        if response.status_code in {301, 302} and response.location:
            if redirect_count >= MAX_REDIRECTS:
                print(f"Error: too many redirects (limit: {MAX_REDIRECTS})", file=sys.stderr)
                return 1
            next_url = urljoin(current_url, response.location)
            print(f"Redirect ({response.status_code}) -> {next_url}")
            current_url = next_url
            redirect_count += 1
            continue
        break

    if response is None:
        print("Network error: empty response", file=sys.stderr)
        return 1

    print(f"Status: {response.status_line}")
    print(f"Status code: {response.status_code}")
    print(f"Content-Type: {response.content_type or '(not set)'}")
    print(f"Location: {response.location or '(not set)'}")
    body_text = decode_body_text(response.body, response.content_type)
    parser = TitleParser()
    parser.feed(body_text)
    print(f"Title: {parser.title or '(no title found)'}")
    print("Content:")
    print(format_response_content(response.body, response.content_type) or "(empty body)")
    return 0


def handle_search(search_term: str) -> int:
    if not search_term:
        print("Error: missing search term after -s", file=sys.stderr)
        return 2
    query = quote_plus(search_term)
    search_url = f"https://duckduckgo.com/?q={query}"
    print(f"Search URL: {search_url}")
    return 0


def main(argv: list[str]) -> int:
    parser = build_parser()
    args = parse_args(argv)

    if args.help or not argv:
        print(parser.format_help())
        return 0

    if args.url and args.search_term:
        print("Error: use either -u or -s, not both", file=sys.stderr)
        return 2

    if args.url is not None:
        return handle_url(args.url, args.timeout)

    if args.search_term is not None:
        return handle_search(args.search_term)

    print("Error: choose one command: -u <URL> or -s <search-term>", file=sys.stderr)
    return 2


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
