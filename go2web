#!/usr/bin/env python3
from __future__ import annotations

import argparse
import base64
import json
import re
import socket
import ssl
import sys
import time
from collections.abc import Callable
from dataclasses import dataclass
from html import unescape
from html.parser import HTMLParser
from pathlib import Path
from textwrap import shorten
from urllib.parse import parse_qs, quote_plus, unquote, urljoin, urlparse

DEFAULT_TIMEOUT = 5.0
USER_AGENT = "go2web/0.1"
MAX_REDIRECTS = 5
SEARCH_ENGINE_HOST = "duckduckgo.com"
SEARCH_RESULTS_LIMIT = 10
CACHE_TTL_SECONDS = 300
CACHE_FILE = Path(__file__).with_name(".go2web_cache.json")
ACCEPT_HEADER = "text/html, application/json"
MAX_OUTPUT_LINE_LENGTH = 120


@dataclass
class ParsedHttpResponse:
    status_line: str
    status_code: int
    headers: dict[str, str]
    content_type: str
    location: str
    body: bytes


@dataclass
class SearchResult:
    title: str
    link: str


class TitleParser(HTMLParser):
    def __init__(self) -> None:
        super().__init__()
        self._in_title = False
        self._parts: list[str] = []

    def handle_starttag(self, tag: str, attrs: list[tuple[str, str | None]]) -> None:
        if tag.lower() == "title":
            self._in_title = True

    def handle_endtag(self, tag: str) -> None:
        if tag.lower() == "title":
            self._in_title = False

    def handle_data(self, data: str) -> None:
        if self._in_title:
            self._parts.append(data)

    @property
    def title(self) -> str:
        return " ".join(p.strip() for p in self._parts if p.strip()).strip()


class VisibleTextParser(HTMLParser):
    def __init__(self) -> None:
        super().__init__()
        self._ignore_depth = 0
        self._parts: list[str] = []

    def handle_starttag(self, tag: str, attrs: list[tuple[str, str | None]]) -> None:
        if tag.lower() in {"script", "style"}:
            self._ignore_depth += 1

    def handle_endtag(self, tag: str) -> None:
        if tag.lower() in {"script", "style"} and self._ignore_depth > 0:
            self._ignore_depth -= 1
        if tag.lower() in {
            "p",
            "br",
            "div",
            "li",
            "section",
            "article",
            "h1",
            "h2",
            "h3",
            "h4",
            "h5",
            "h6",
            "ul",
            "ol",
        }:
            self._parts.append("\n")

    def handle_data(self, data: str) -> None:
        if self._ignore_depth == 0:
            text = re.sub(r"\s+", " ", data).strip()
            if text:
                if self._parts and not self._parts[-1].endswith("\n"):
                    self._parts.append(" ")
                self._parts.append(text)

    def get_text(self) -> str:
        merged = "".join(self._parts)
        merged = re.sub(r"[ \t]+", " ", merged)
        merged = re.sub(r"\n{3,}", "\n\n", merged)
        lines = [line.strip() for line in merged.splitlines()]
        lines = [line for line in lines if line]
        return "\n".join(lines)


class SearchResultsParser(HTMLParser):
    def __init__(self) -> None:
        super().__init__()
        self._result_block_depth = 0
        self._in_result_link = False
        self._current_href = ""
        self._current_title_parts: list[str] = []
        self.results: list[SearchResult] = []
        self._seen: set[tuple[str, str]] = set()

    def handle_starttag(self, tag: str, attrs: list[tuple[str, str | None]]) -> None:
        tag_name = tag.lower()
        attr_map = {k.lower(): (v or "") for k, v in attrs}
        css_classes = set(attr_map.get("class", "").split())

        # DuckDuckGo result links in /html endpoint.
        if tag_name == "a" and "result__a" in css_classes:
            href = attr_map.get("href", "").strip()
            if href and not href.startswith("#"):
                self._in_result_link = True
                self._current_href = href
                self._current_title_parts = []
            return

        if tag_name == "li":
            if {"b_algo", "algo", "webalgo"} & css_classes:
                self._result_block_depth = 1
                return
            if self._result_block_depth > 0:
                self._result_block_depth += 1
                return

        if self._result_block_depth == 0:
            return

        if tag_name != "a":
            return

        href = attr_map.get("href", "").strip()
        if not href:
            return
        if href.startswith("#"):
            return

        self._in_result_link = True
        self._current_href = href
        self._current_title_parts = []

    def handle_data(self, data: str) -> None:
        if self._in_result_link:
            self._current_title_parts.append(data)

    def handle_endtag(self, tag: str) -> None:
        tag_name = tag.lower()
        if tag_name == "a" and self._in_result_link:
            raw_title = " ".join(part.strip() for part in self._current_title_parts if part.strip()).strip()
            title = unescape(raw_title)
            link = normalize_search_result_link(self._current_href)
            if title and link:
                key = (title, link)
                if key not in self._seen:
                    self.results.append(SearchResult(title=title, link=link))
                    self._seen.add(key)
            self._in_result_link = False
            self._current_href = ""
            self._current_title_parts = []
            return

        if tag_name == "li" and self._result_block_depth > 0:
            self._result_block_depth -= 1
            if self._result_block_depth == 0:
                self._in_result_link = False
                self._current_href = ""
                self._current_title_parts = []
            return


def normalize_search_result_link(link: str) -> str:
    parsed = urlparse(link)
    if link.startswith("//"):
        return f"https:{link}"
    params = parse_qs(parsed.query)
    target = params.get("uddg", [""])[0]
    if target:
        return unquote(target)
    if parsed.scheme in {"http", "https"}:
        return link
    if parsed.path and parsed.path.startswith("/"):
        return urljoin(f"https://{SEARCH_ENGINE_HOST}", parsed.path)
    return link


def load_cache_store() -> dict[str, object]:
    if not CACHE_FILE.exists():
        return {}
    try:
        raw = CACHE_FILE.read_text(encoding="utf-8")
        data = json.loads(raw)
        if isinstance(data, dict):
            return data
    except (OSError, json.JSONDecodeError):
        return {}
    return {}


def save_cache_store(cache: dict[str, object]) -> None:
    try:
        CACHE_FILE.write_text(json.dumps(cache, ensure_ascii=False, indent=2), encoding="utf-8")
    except OSError:
        pass


def serialize_response(response: ParsedHttpResponse) -> dict[str, object]:
    return {
        "status_line": response.status_line,
        "status_code": response.status_code,
        "headers": response.headers,
        "content_type": response.content_type,
        "location": response.location,
        "body_b64": base64.b64encode(response.body).decode("ascii"),
    }


def deserialize_response(data: object) -> ParsedHttpResponse | None:
    if not isinstance(data, dict):
        return None
    try:
        status_line = str(data.get("status_line", "HTTP/1.1 000 Unknown"))
        status_code = int(data.get("status_code", 0))
        headers_obj = data.get("headers", {})
        headers = {str(k).lower(): str(v) for k, v in dict(headers_obj).items()}
        content_type = str(data.get("content_type", ""))
        location = str(data.get("location", ""))
        body = base64.b64decode(str(data.get("body_b64", "")), validate=False)
    except (ValueError, TypeError):
        return None
    return ParsedHttpResponse(
        status_line=status_line,
        status_code=status_code,
        headers=headers,
        content_type=content_type,
        location=location,
        body=body,
    )


def get_cached_response(url: str) -> tuple[str, ParsedHttpResponse] | None:
    cache = load_cache_store()
    entry = cache.get(url)
    if not isinstance(entry, dict):
        return None

    now = time.time()
    expires_at = float(entry.get("expires_at", 0.0))
    if expires_at <= now:
        cache.pop(url, None)
        save_cache_store(cache)
        return None

    final_url = str(entry.get("final_url", url))
    response = deserialize_response(entry.get("response"))
    if response is None:
        cache.pop(url, None)
        save_cache_store(cache)
        return None
    return final_url, response


def put_cached_response(url: str, final_url: str, response: ParsedHttpResponse) -> None:
    cache = load_cache_store()
    now = time.time()

    # Cleanup expired items before writing.
    expired_keys = [
        key
        for key, value in cache.items()
        if isinstance(value, dict) and float(value.get("expires_at", 0.0)) <= now
    ]
    for key in expired_keys:
        cache.pop(key, None)

    cache[url] = {
        "expires_at": now + CACHE_TTL_SECONDS,
        "final_url": final_url,
        "response": serialize_response(response),
    }
    save_cache_store(cache)


def decode_body_text(body: bytes, content_type: str) -> str:
    charset = "utf-8"
    for part in content_type.split(";")[1:]:
        name, sep, value = part.strip().partition("=")
        if sep and name.lower() == "charset" and value:
            charset = value.strip().strip('"').strip("'")
            break
    return body.decode(charset, errors="replace")


def clean_and_limit_text(text: str, max_len: int = MAX_OUTPUT_LINE_LENGTH) -> str:
    cleaned_lines: list[str] = []
    for raw_line in text.splitlines():
        line = re.sub(r"\s+", " ", raw_line).strip()
        if not line:
            continue
        if len(line) > max_len:
            line = shorten(line, width=max_len, placeholder=" ...")
        cleaned_lines.append(line)
    return "\n".join(cleaned_lines)


def limit_long_lines_preserve_structure(text: str, max_len: int = MAX_OUTPUT_LINE_LENGTH) -> str:
    lines: list[str] = []
    for raw_line in text.splitlines():
        if len(raw_line) <= max_len:
            lines.append(raw_line.rstrip())
            continue
        lines.append(shorten(raw_line, width=max_len, placeholder=" ..."))
    return "\n".join(lines).rstrip()


def to_console_safe(text: str) -> str:
    encoding = sys.stdout.encoding or "utf-8"
    return text.encode(encoding, errors="replace").decode(encoding, errors="replace")


def format_response_content(body: bytes, content_type: str) -> str:
    lowered = content_type.lower()
    text = decode_body_text(body, content_type)

    if "application/json" in lowered or lowered.endswith("+json"):
        try:
            parsed = json.loads(text)
            pretty = json.dumps(parsed, indent=2, ensure_ascii=False)
            return limit_long_lines_preserve_structure(pretty)
        except json.JSONDecodeError:
            return clean_and_limit_text(text)

    if "text/html" in lowered:
        parser = VisibleTextParser()
        parser.feed(text)
        return clean_and_limit_text(unescape(parser.get_text()))

    return clean_and_limit_text(text)


def format_network_error(exc: Exception) -> tuple[str, int]:
    if isinstance(exc, socket.gaierror):
        return "DNS lookup failed. Check the host name and your internet connection.", 1
    if isinstance(exc, ConnectionRefusedError):
        return "Connection refused by the remote host.", 1
    if isinstance(exc, (TimeoutError, socket.timeout)):
        return "Connection timed out. The server did not respond in time.", 1
    if isinstance(exc, ssl.SSLError):
        return "TLS/SSL handshake failed for HTTPS connection.", 1
    if isinstance(exc, ValueError):
        message = str(exc)
        if "too many redirects" in message.lower():
            return f"Redirect error: {message}.", 1
        return f"Invalid URL or response format: {message}", 2
    return f"Network error: {exc}", 1


def run_with_user_friendly_network_errors(action: Callable[[], int]) -> int:
    try:
        return action()
    except (OSError, ssl.SSLError, ValueError) as exc:
        message, code = format_network_error(exc)
        print(f"Error: {message}", file=sys.stderr)
        return code


def recv_all(sock: socket.socket) -> bytes:
    chunks: list[bytes] = []
    while True:
        chunk = sock.recv(4096)
        if not chunk:
            break
        chunks.append(chunk)
    return b"".join(chunks)


def parse_http_response(raw_response: bytes) -> ParsedHttpResponse:
    header_end = raw_response.find(b"\r\n\r\n")
    if header_end == -1:
        raise ValueError("Invalid HTTP response: missing header separator")

    header_blob = raw_response[:header_end].decode("iso-8859-1", errors="replace")
    body = raw_response[header_end + 4 :]
    header_lines = header_blob.split("\r\n")
    status_line = header_lines[0] if header_lines else "HTTP/1.1 000 Unknown"

    headers: dict[str, str] = {}
    for line in header_lines[1:]:
        if ":" not in line:
            continue
        key, value = line.split(":", 1)
        headers[key.strip().lower()] = value.strip()
    status_code = 0
    parts = status_line.split()
    if len(parts) >= 2 and parts[1].isdigit():
        status_code = int(parts[1])

    return ParsedHttpResponse(
        status_line=status_line,
        status_code=status_code,
        headers=headers,
        content_type=headers.get("content-type", ""),
        location=headers.get("location", ""),
        body=body,
    )


def decode_chunked_body(chunked: bytes) -> bytes:
    data = chunked
    decoded = bytearray()
    idx = 0

    while True:
        line_end = data.find(b"\r\n", idx)
        if line_end == -1:
            raise ValueError("Invalid chunked response: missing chunk size line")
        size_line = data[idx:line_end].decode("ascii", errors="replace").strip()
        size_token = size_line.split(";", 1)[0].strip()
        try:
            chunk_size = int(size_token, 16)
        except ValueError as exc:
            raise ValueError("Invalid chunked response: bad chunk size") from exc

        idx = line_end + 2
        if chunk_size == 0:
            break

        chunk_end = idx + chunk_size
        if chunk_end > len(data):
            raise ValueError("Invalid chunked response: incomplete chunk")
        decoded.extend(data[idx:chunk_end])
        idx = chunk_end + 2  # Skip trailing CRLF after chunk data.

    return bytes(decoded)


def fetch_http_via_socket(
    host: str, port: int, path: str, timeout: float, use_tls: bool
) -> ParsedHttpResponse:
    default_port = 443 if use_tls else 80
    host_header = host if port == default_port else f"{host}:{port}"
    request = (
        f"GET {path} HTTP/1.1\r\n"
        f"Host: {host_header}\r\n"
        f"User-Agent: {USER_AGENT}\r\n"
        f"Accept: {ACCEPT_HEADER}\r\n"
        "Connection: close\r\n"
        "\r\n"
    ).encode("ascii", errors="replace")

    with socket.create_connection((host, port), timeout=timeout) as sock:
        if use_tls:
            context = ssl.create_default_context()
            with context.wrap_socket(sock, server_hostname=host) as tls_sock:
                tls_sock.sendall(request)
                raw_response = recv_all(tls_sock)
        else:
            sock.sendall(request)
            raw_response = recv_all(sock)

    response = parse_http_response(raw_response)
    transfer_encoding = response.headers.get("transfer-encoding", "").lower()
    if "chunked" in transfer_encoding:
        response.body = decode_chunked_body(response.body)
    return response


def fetch_url_follow_redirects(url: str, timeout: float) -> tuple[str, ParsedHttpResponse, bool]:
    cached = get_cached_response(url)
    if cached is not None:
        final_url, response = cached
        return final_url, response, True

    current_url = url
    redirect_count = 0

    while True:
        scheme, host, port, path = parse_web_url(current_url)
        response = fetch_http_via_socket(
            host=host, port=port, path=path, timeout=timeout, use_tls=(scheme == "https")
        )
        if response.status_code in {301, 302} and response.location:
            if redirect_count >= MAX_REDIRECTS:
                raise ValueError(f"too many redirects (limit: {MAX_REDIRECTS})")
            current_url = urljoin(current_url, response.location)
            redirect_count += 1
            continue
        put_cached_response(url, current_url, response)
        return current_url, response, False


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="go2web",
        add_help=False,
        formatter_class=argparse.RawTextHelpFormatter,
        description=(
            "go2web - CLI web helper\n\n"
            "Usage:\n"
            "  go2web -h\n"
            "  go2web -u <URL>\n"
            "  go2web -s <search-term>"
        ),
    )
    parser.add_argument("-h", "--help", action="store_true", help="Show this help message and exit")
    parser.add_argument("-u", metavar="URL", dest="url", help="Fetch URL and print page title")
    parser.add_argument("-s", metavar="TERM", dest="search_term", help="Search term handler")
    parser.add_argument("--timeout", type=float, default=DEFAULT_TIMEOUT, help="HTTP timeout in seconds")
    return parser


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = build_parser()
    return parser.parse_args(argv)


def parse_web_url(url: str) -> tuple[str, str, int, str]:
    parsed = urlparse(url)
    scheme = parsed.scheme.lower()
    if scheme not in {"http", "https"}:
        raise ValueError("Only http:// and https:// URLs are supported")
    if not parsed.hostname:
        raise ValueError("Invalid URL: missing host")

    host = parsed.hostname
    default_port = 443 if scheme == "https" else 80
    port = parsed.port or default_port
    path = parsed.path if parsed.path else "/index.html"
    if parsed.query:
        path = f"{path}?{parsed.query}"
    return scheme, host, port, path


def handle_url(url: str, timeout: float) -> int:
    if not url:
        print("Error: missing URL after -u", file=sys.stderr)
        return 2
    def _run() -> int:
        final_url, response, cache_hit = fetch_url_follow_redirects(url, timeout)
        scheme, host, port, path = parse_web_url(final_url)

        print(f"Final URL: {final_url}")
        print(f"Cache: {'HIT' if cache_hit else 'MISS'}")
        print(f"Scheme: {scheme}")
        print(f"Host: {host}")
        print(f"Port: {port}")
        print(f"Path: {path}")

        print(f"Status: {response.status_line}")
        print(f"Status code: {response.status_code}")
        print(f"Content-Type: {response.content_type or '(not set)'}")
        print(f"Location: {response.location or '(not set)'}")
        body_text = decode_body_text(response.body, response.content_type)
        parser = TitleParser()
        parser.feed(body_text)
        print(f"Title: {parser.title or '(no title found)'}")
        print("Content:")
        content = format_response_content(response.body, response.content_type) or "(empty body)"
        print(to_console_safe(content))
        return 0

    return run_with_user_friendly_network_errors(_run)


def handle_search(search_term: str, timeout: float) -> int:
    if not search_term:
        print("Error: missing search term after -s", file=sys.stderr)
        return 2

    query = quote_plus(search_term)
    search_url = f"https://{SEARCH_ENGINE_HOST}/html/?q={query}"
    print(f"Search URL: {search_url}")

    def _run() -> int:
        final_url, response, cache_hit = fetch_url_follow_redirects(search_url, timeout)

        if response.status_code < 200 or response.status_code >= 300:
            print(f"Search failed with status {response.status_code}: {response.status_line}", file=sys.stderr)
            return 1

        html = decode_body_text(response.body, response.content_type)
        parser = SearchResultsParser()
        parser.feed(html)

        if final_url != search_url:
            print(f"Final URL: {final_url}")
        print(f"Cache: {'HIT' if cache_hit else 'MISS'}")
        if not parser.results:
            print("No search results found.")
            return 0

        print(f"Top {min(SEARCH_RESULTS_LIMIT, len(parser.results))} results:")
        for idx, item in enumerate(parser.results[:SEARCH_RESULTS_LIMIT], start=1):
            title = clean_and_limit_text(item.title, max_len=90) or "(untitled)"
            direct_link = normalize_search_result_link(item.link)
            link = clean_and_limit_text(direct_link, max_len=10000) or "(no link)"
            print(to_console_safe(f"[{idx}] {title} - {link}"))
        return 0

    return run_with_user_friendly_network_errors(_run)


def main(argv: list[str]) -> int:
    parser = build_parser()
    args = parse_args(argv)

    if args.help or not argv:
        print(parser.format_help())
        return 0

    if args.url and args.search_term:
        print("Error: use either -u or -s, not both", file=sys.stderr)
        return 2

    if args.url is not None:
        return handle_url(args.url, args.timeout)

    if args.search_term is not None:
        return handle_search(args.search_term, args.timeout)

    print("Error: choose one command: -u <URL> or -s <search-term>", file=sys.stderr)
    return 2


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
